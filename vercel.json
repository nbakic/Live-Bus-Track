{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/bus-tracker run build",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
